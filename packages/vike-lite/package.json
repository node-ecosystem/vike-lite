{
  "name": "vike-lite",
  "version": "1.13.3",
  "license": "MIT",
  "type": "module",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "import": "./dist/vite.mjs"
    },
    "./client/router": {
      "import": "./dist/client/router.mjs",
      "types": "./dist/client/router.d.mts"
    },
    "./server": {
      "types": "./dist/server.d.mts",
      "import": "./dist/server.mjs"
    },
    "./server/abort": {
      "import": "./dist/server/abort.mjs",
      "types": "./dist/server/abort.d.mts"
    },
    "./__internal/shared": {
      "types": "./dist/__internal/shared.d.mts",
      "import": "./dist/__internal/shared.mjs"
    },
    "./__internal/server": {
      "types": "./dist/__internal/server.d.mts",
      "import": "./dist/__internal/server.mjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/node-ecosystem/vike-lite.git"
  },
  "homepage": "https://github.com/node-ecosystem/vike-lite#readme",
  "bugs": {
    "url": "https://github.com/node-ecosystem/vike-lite/issues"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "tsc": "tsc --noEmit",
    "build": "tsdown"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsdown": "^0.22.7",
    "vite": "^8.1.4"
  },
  "peerDependencies": {
    "vite": ">=8"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
