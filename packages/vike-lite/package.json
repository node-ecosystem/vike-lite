{
  "name": "vike-lite",
  "version": "1.16.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/node-ecosystem/vike-lite.git"
  },
  "homepage": "https://github.com/node-ecosystem/vike-lite#readme",
  "bugs": {
    "url": "https://github.com/node-ecosystem/vike-lite/issues"
  },
  "keywords": [
    "framework",
    "lite",
    "react",
    "react-ssr",
    "server-side-rendering",
    "solid",
    "solid-js",
    "solid-ssr",
    "solidjs",
    "ssg",
    "ssr",
    "static-site-generator",
    "vike",
    "vike-lite",
    "vite",
    "vite-plugin",
    "vite-ssr",
    "vitejs",
    "vue",
    "vue-ssr",
    "web-framework"
  ],
  "type": "module",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "import": "./dist/vite.mjs"
    },
    "./client/router": {
      "import": "./dist/client/router.mjs",
      "types": "./dist/client/router.d.mts"
    },
    "./server": {
      "types": "./dist/server.d.mts",
      "import": "./dist/server.mjs"
    },
    "./server/abort": {
      "import": "./dist/server/abort.mjs",
      "types": "./dist/server/abort.d.mts"
    },
    "./__internal/shared": {
      "types": "./dist/__internal/shared.d.mts",
      "import": "./dist/__internal/shared.mjs"
    },
    "./__internal/client": {
      "types": "./dist/__internal/client.d.mts",
      "import": "./dist/__internal/client.mjs"
    },
    "./__internal/server": {
      "types": "./dist/__internal/server.d.mts",
      "import": "./dist/__internal/server.mjs"
    },
    "./__internal/vite": {
      "types": "./dist/__internal/vite.d.mts",
      "import": "./dist/__internal/vite.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "tsc": "tsc --noEmit",
    "build": "tsdown"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsdown": "^0.22.13",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "vite": ">=8"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
