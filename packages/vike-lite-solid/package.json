{
  "name": "vike-lite-solid",
  "version": "1.3.0",
  "license": "MIT",
  "type": "module",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "solid": "./src/index.ts",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./vite": {
      "import": "./dist/vite.mjs",
      "types": "./dist/vite.d.mts"
    },
    "./__internal/client/onRenderClient": {
      "solid": "./src/__internal/client/onRenderClient.tsx",
      "import": "./src/__internal/client/onRenderClient.tsx"
    },
    "./__internal/server/onRenderHtml": {
      "solid": "./src/__internal/server/onRenderHtml.tsx",
      "import": "./src/__internal/server/onRenderHtml.tsx"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/node-ecosystem/vike-lite-solid.git"
  },
  "homepage": "https://github.com/node-ecosystem/vike-lite-solid#readme",
  "bugs": {
    "url": "https://github.com/node-ecosystem/vike-lite-solid/issues"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "solid-js": "^1.9.13",
    "tsdown": "^0.22.3",
    "vike-lite": "workspace:*",
    "vite": "^8.1.0",
    "vite-plugin-solid": "^2.11.12"
  },
  "peerDependencies": {
    "solid-js": "*",
    "vike-lite": "*",
    "vite": ">=8",
    "vite-plugin-solid": "*"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
