{
  "name": "vike-lite-svelte",
  "version": "1.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/node-ecosystem/vike-lite.git"
  },
  "homepage": "https://github.com/node-ecosystem/vike-lite#readme",
  "bugs": {
    "url": "https://github.com/node-ecosystem/vike-lite/issues"
  },
  "keywords": [
    "framework",
    "lite",
    "server-side-rendering",
    "svelte",
    "svelte-ssr",
    "sveltejs",
    "ssg",
    "ssr",
    "static-site-generator",
    "vike",
    "vike-lite",
    "vite",
    "vite-plugin",
    "vite-ssr",
    "vitejs",
    "web-framework"
  ],
  "type": "module",
  "exports": {
    ".": {
      "svelte": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "import": "./dist/vite.mjs"
    },
    "./__internal/client/onRenderClient": {
      "svelte": "./src/__internal/client/onRenderClient.ts",
      "import": "./src/__internal/client/onRenderClient.ts"
    },
    "./__internal/server/onRenderHtml": {
      "svelte": "./src/__internal/server/onRenderHtml.ts",
      "import": "./src/__internal/server/onRenderHtml.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "tsc": "tsc --noEmit",
    "build": "tsdown"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@types/node": "^26.1.1",
    "jsdom": "^29.1.1",
    "svelte": "^5.56.6",
    "tsdown": "^0.22.11",
    "vike-lite": "workspace:*",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "@sveltejs/vite-plugin-svelte": ">=7",
    "svelte": "*",
    "vike-lite": "*",
    "vite": ">=8"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
