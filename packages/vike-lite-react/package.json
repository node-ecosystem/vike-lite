{
  "name": "vike-lite-react",
  "version": "1.0.9",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/node-ecosystem/vike-lite.git"
  },
  "homepage": "https://github.com/node-ecosystem/vike-lite#readme",
  "bugs": {
    "url": "https://github.com/node-ecosystem/vike-lite/issues"
  },
  "keywords": [
    "framework",
    "lite",
    "react",
    "react-ssr",
    "server-side-rendering",
    "ssg",
    "ssr",
    "static-site-generator",
    "vike",
    "vike-lite",
    "vite",
    "vite-plugin",
    "vite-ssr",
    "vitejs",
    "web-framework"
  ],
  "type": "module",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "import": "./dist/vite.mjs"
    },
    "./__internal/client/onRenderClient": {
      "types": "./dist/__internal/client/onRenderClient.d.mts",
      "import": "./dist/__internal/client/onRenderClient.mjs"
    },
    "./__internal/server/onRenderHtml": {
      "types": "./dist/__internal/server/onRenderHtml.d.mts",
      "import": "./dist/__internal/server/onRenderHtml.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "tsc": "tsc --noEmit",
    "build": "tsdown"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsdown": "^0.22.8",
    "vike-lite": "workspace:*",
    "vite": "^8.1.5"
  },
  "peerDependencies": {
    "@vitejs/plugin-react": ">=6",
    "react": "*",
    "react-dom": "*",
    "vike-lite": "*",
    "vite": ">=8"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
